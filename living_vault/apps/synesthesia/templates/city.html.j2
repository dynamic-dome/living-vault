<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{ title }} | city</title>
  <style>
    html, body { margin:0; height:100%; background:#0c1014; color:#cfe; font-family:'JetBrains Mono', monospace; overflow:hidden; }
    #info { position:fixed; top:8px; left:8px; padding:6px 10px; background:rgba(0,0,0,.6); border-radius:4px; font-size:12px; z-index:10; }
    #picked { position:fixed; bottom:8px; left:8px; padding:8px 12px; background:rgba(0,0,0,.7); border-radius:4px; font-size:12px; max-width:60ch; white-space:pre-wrap; z-index:10; pointer-events:none; }
    #legend { position:fixed; top:8px; right:8px; padding:8px 12px; background:rgba(0,0,0,.6); border-radius:4px; font-size:11px; line-height:1.5; z-index:10; max-width:200px; }
    .swatch { display:inline-block; width:10px; height:10px; margin-right:6px; vertical-align:middle; border-radius:2px; }
  </style>
</head>
<body>
  <div id="info">{{ count }} pages | {{ edge_count }} links | city mode | drag/scroll | hover for highlight</div>
  <div id="picked"></div>
  <div id="legend"></div>
  <script type="importmap">
  { "imports": {
      "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
      "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
  }}
  </script>
  <script type="module">
    import * as THREE from "three";
    import { OrbitControls } from "three/addons/controls/OrbitControls.js";

    const NODES = {{ nodes_json | safe }};
    const EDGES = {{ edges_json | safe }};

    const PALETTE = [
      "#ff5470","#06d6a0","#ffd166","#118ab2","#ef476f",
      "#8338ec","#ff006e","#3a86ff","#fb5607","#ffbe0b",
      "#06ffa5","#a162e8","#fcaeae"
    ];
    const clusterMap = {};
    function colorOf(c) {
      if (!(c in clusterMap)) clusterMap[c] = PALETTE[Object.keys(clusterMap).length % PALETTE.length];
      return clusterMap[c];
    }
    NODES.forEach(n => colorOf(n.cluster));

    // Cluster-bias: push each cluster to its own quadrant in addition to PCA
    // Compute centroids, then offset each node by cluster index direction
    const clusterCentroids = {};
    NODES.forEach(n => {
      if (!(n.cluster in clusterCentroids)) clusterCentroids[n.cluster] = {x:0,y:0,z:0,n:0};
      clusterCentroids[n.cluster].x += n.x;
      clusterCentroids[n.cluster].y += n.y;
      clusterCentroids[n.cluster].z += n.z;
      clusterCentroids[n.cluster].n += 1;
    });
    const clusters = Object.keys(clusterCentroids);
    clusters.forEach(c => {
      const cd = clusterCentroids[c];
      cd.x /= cd.n; cd.y /= cd.n; cd.z /= cd.n;
    });
    // assign each cluster a stable offset on a sphere
    const SPREAD = 80;
    const clusterOffsets = {};
    clusters.forEach((c, i) => {
      const phi = Math.acos(1 - 2*(i+0.5)/clusters.length);
      const theta = Math.PI * (1 + Math.sqrt(5)) * (i+0.5);  // golden angle
      clusterOffsets[c] = {
        x: SPREAD * Math.sin(phi) * Math.cos(theta),
        y: SPREAD * Math.sin(phi) * Math.sin(theta),
        z: SPREAD * Math.cos(phi),
      };
    });

    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog(0x0c1014, 200, 900);
    const camera = new THREE.PerspectiveCamera(60, innerWidth/innerHeight, 0.1, 8000);
    camera.position.set(280, 280, 280);
    const renderer = new THREE.WebGLRenderer({ antialias:true });
    renderer.setSize(innerWidth, innerHeight);
    renderer.setPixelRatio(devicePixelRatio);
    document.body.appendChild(renderer.domElement);
    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true; controls.dampingFactor = 0.08;

    scene.add(new THREE.AmbientLight(0xffffff, 0.4));
    const dir = new THREE.DirectionalLight(0xffffff, 0.9);
    dir.position.set(100,200,100); scene.add(dir);

    // shared geometry for performance
    const sharedGeom = new THREE.SphereGeometry(1, 16, 12);
    const meshes = [];
    const positions = NODES.map(n => {
      const off = clusterOffsets[n.cluster];
      return new THREE.Vector3(n.x + off.x, n.y + off.y, n.z + off.z);
    });
    NODES.forEach((n, i) => {
      const r = 0.6 + Math.log(1 + (n.degree || 0)) * 0.45;
      const mat = new THREE.MeshStandardMaterial({
        color: colorOf(n.cluster), roughness: 0.5, metalness: 0.1,
      });
      const mesh = new THREE.Mesh(sharedGeom, mat);
      mesh.scale.setScalar(r);
      mesh.position.copy(positions[i]);
      mesh.userData = { node: n, baseColor: new THREE.Color(colorOf(n.cluster)), index: i };
      scene.add(mesh);
      meshes.push(mesh);
    });

    // edges
    const edgePositions = [];
    const nodeIndex = Object.fromEntries(NODES.map((n,i)=>[n.path,i]));
    const edgeIndices = [];  // pairs (i,j) for highlighting
    EDGES.forEach(e => {
      const ai = nodeIndex[e.from]; const bi = nodeIndex[e.to];
      if (ai === undefined || bi === undefined) return;
      const a = positions[ai]; const b = positions[bi];
      edgePositions.push(a.x,a.y,a.z, b.x,b.y,b.z);
      edgeIndices.push([ai, bi]);
    });
    const edgeGeom = new THREE.BufferGeometry();
    edgeGeom.setAttribute("position", new THREE.Float32BufferAttribute(edgePositions, 3));
    const edgeColors = new Float32Array(edgePositions.length);
    edgeGeom.setAttribute("color", new THREE.BufferAttribute(edgeColors, 3));
    function setAllEdgeColors(r,g,b,opacity) {
      for (let i=0; i<edgeColors.length; i+=3) {
        edgeColors[i]=r*opacity; edgeColors[i+1]=g*opacity; edgeColors[i+2]=b*opacity;
      }
      edgeGeom.attributes.color.needsUpdate = true;
    }
    setAllEdgeColors(0.4, 0.55, 0.85, 0.18);
    const edgeMat = new THREE.LineBasicMaterial({
      vertexColors: true, transparent: true, opacity: 1.0, depthWrite: false,
      blending: THREE.AdditiveBlending,
    });
    const edgeLines = new THREE.LineSegments(edgeGeom, edgeMat);
    scene.add(edgeLines);

    // adjacency: per-node list of edge-indices for fast hover-highlight
    const adjacency = NODES.map(()=>[]);
    edgeIndices.forEach(([a,b], ei) => { adjacency[a].push(ei); adjacency[b].push(ei); });

    // hover highlight
    const ray = new THREE.Raycaster();
    const mouse = new THREE.Vector2();
    addEventListener("mousemove", (ev) => {
      mouse.x = (ev.clientX / innerWidth) * 2 - 1;
      mouse.y = -(ev.clientY / innerHeight) * 2 + 1;
    });
    let lastHoverIdx = -1;

    function applyHover(idx) {
      // dim all meshes, brighten the hovered one + its neighbors
      meshes.forEach((m, i) => {
        const base = m.userData.baseColor;
        const target = (idx < 0) ? base : (i === idx ? base : base.clone().multiplyScalar(0.3));
        m.material.color.copy(target);
      });
      if (idx >= 0) {
        // brighten neighbors via adjacency
        adjacency[idx].forEach(ei => {
          const [a,b] = edgeIndices[ei];
          const other = a === idx ? b : a;
          meshes[other].material.color.copy(meshes[other].userData.baseColor);
        });
      }
      // edge colors: dim all, brighten incident edges
      const dimR=0.3, dimG=0.4, dimB=0.6, dimO=0.05;
      const hotR=1.0, hotG=0.95, hotB=0.5, hotO=0.9;
      for (let i=0; i<edgeColors.length; i+=3) {
        edgeColors[i]=dimR*dimO; edgeColors[i+1]=dimG*dimO; edgeColors[i+2]=dimB*dimO;
      }
      if (idx >= 0) {
        adjacency[idx].forEach(ei => {
          const off = ei * 6;
          edgeColors[off]   = hotR*hotO; edgeColors[off+1] = hotG*hotO; edgeColors[off+2] = hotB*hotO;
          edgeColors[off+3] = hotR*hotO; edgeColors[off+4] = hotG*hotO; edgeColors[off+5] = hotB*hotO;
        });
      } else {
        // restore base subtle look
        for (let i=0; i<edgeColors.length; i+=3) {
          edgeColors[i]=0.4*0.18; edgeColors[i+1]=0.55*0.18; edgeColors[i+2]=0.85*0.18;
        }
      }
      edgeGeom.attributes.color.needsUpdate = true;
    }

    function tick() {
      requestAnimationFrame(tick);
      controls.update();
      ray.setFromCamera(mouse, camera);
      const hits = ray.intersectObjects(meshes, false);
      const pickedEl = document.getElementById("picked");
      let idx = -1;
      if (hits.length > 0) {
        idx = hits[0].object.userData.index;
        const n = hits[0].object.userData.node;
        pickedEl.textContent = `${n.cluster}/${n.title}\n${n.path}\nlinks: ${n.degree}`;
      } else {
        pickedEl.textContent = "";
      }
      if (idx !== lastHoverIdx) {
        applyHover(idx);
        lastHoverIdx = idx;
      }
      renderer.render(scene, camera);
    }
    tick();

    // legend
    const legendEl = document.getElementById("legend");
    Object.entries(clusterMap).slice(0, 14).forEach(([c, color]) => {
      const div = document.createElement("div");
      div.innerHTML = `<span class="swatch" style="background:${color}"></span>${c}`;
      legendEl.appendChild(div);
    });

    addEventListener("resize", () => {
      camera.aspect = innerWidth/innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(innerWidth, innerHeight);
    });
  </script>
</body>
</html>
